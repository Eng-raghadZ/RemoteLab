# URL of the API server's agent WebSocket endpoint.
# Use wss:// in production; ws:// is fine for local development.
API_WS_URL=ws://localhost:4000/ws/agent

# Must match AGENT_SHARED_SECRET in the backend's .env exactly.
AGENT_SHARED_SECRET=replace-with-a-long-random-string

# Reconnect backoff (milliseconds) if the connection to the API server drops.
RECONNECT_DELAY_MS=3000

# --- Trainer kit interface (stubbed for now — see src/trainerKit.js) ---
# Serial port the interface controller is attached to, once confirmed.
# Example: /dev/ttyUSB0 (Linux) or COM3 (Windows).
SERIAL_PORT=
SERIAL_BAUD_RATE=9600

# --- Camera relay (stubbed for now — see src/cameraCapture.js) ---
# How often a frame is captured/sent while a job is running (milliseconds).
CAMERA_FRAME_INTERVAL_MS=1000

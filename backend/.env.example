# Port the API server listens on
PORT=4000

# Origin allowed to call this API (your frontend's URL). Use a comma-separated
# list if you need more than one, or "*" for local development only.
ALLOWED_ORIGIN=http://localhost:5173

# --- Firebase Admin SDK credentials ---
# Generate these from: Firebase Console -> Project Settings -> Service Accounts
# -> Generate new private key. Copy the three values below out of that JSON file.
# Do NOT commit the actual JSON key or a filled-in .env file to git.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENTS_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Storage bucket that will hold uploaded .asm files
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# --- Phase 2: WebSocket bridge to the Lab Agent ---

# Shared secret the on-prem Lab Agent must present when it connects to
# /ws/agent. Generate a long random string, e.g.: openssl rand -hex 32
# Must match AGENT_SHARED_SECRET in lab-agent/.env exactly.
AGENT_SHARED_SECRET=replace-with-a-long-random-string

# How long a job may execute before it's force-terminated (milliseconds).
# Matches the 5-minute cap from the Execution Queue & Camera Session Policy.
EXECUTION_TIMEOUT_MS=300000

# How long the server waits for the Lab Agent to acknowledge a dispatched
# job (job_started) before treating the dispatch as failed (milliseconds).
DISPATCH_ACK_TIMEOUT_MS=15000
